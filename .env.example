# Device types to simulate/monitor (comma-separated)
DEVICE_TYPES=server,workstation,iot_sensor

# Telemetry window length fed to the encoder, in minutes
WINDOW_SIZE=10

# LLM backend for the diagnostic agent layer (Phase 5)
#   ollama -> local, required for production ("no telemetry leaves the network")
#   groq   -> cloud, prototyping only
LLM_BACKEND=groq
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Vector store for runbook RAG (Phase 5)
#   faiss  -> local on-disk index, default
#   chroma -> local on-disk, alternative
#   postgres -> local Postgres+pgvector connection string (NOT a hosted/cloud instance)
VECTOR_STORE=faiss
VECTOR_STORE_PATH=./runbooks/index

# API (Phase 6)
API_HOST=0.0.0.0
API_PORT=8000
